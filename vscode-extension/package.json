{
  "name": "skillgate-vscode-extension",
  "displayName": "SkillGate",
  "publisher": "skillgate-io",
  "description": "Protect Claude Code and Codex workflows in VS Code with real-time safety checks and clear policy feedback.",
  "version": "0.12.2",
  "icon": "assets/extension-icon-square-512.png",
  "license": "MIT",
  "homepage": "https://skillgate.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/skillgate-io/skillgate.git"
  },
  "bugs": {
    "url": "https://github.com/skillgate-io/skillgate/issues"
  },
  "keywords": [
    "skillgate",
    "ai agent security",
    "prompt injection",
    "vscode security extension",
    "claude code",
    "codex cli",
    "policy enforcement",
    "devsecops"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Security",
    "Linters",
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:skillgate.simulateInvocation",
    "onCommand:skillgate.openOnboarding",
    "onCommand:skillgate.initPolicyFile",
    "onCommand:skillgate.scanWorkspace",
    "onCommand:skillgate.submitScanReport",
    "onCommand:skillgate.generatePrChecklist",
    "onCommand:skillgate.openApprovalRequest",
    "onCommand:skillgate.signApproval",
    "onCommand:skillgate.verifyApproval",
    "onCommand:skillgate.openApprovalCenter",
    "workspaceContains:.skillgate.yml",
    "workspaceContains:skill.json",
    "workspaceContains:SKILL.md",
    "workspaceContains:CLAUDE.md",
    "workspaceContains:AGENTS.md",
    "workspaceContains:MEMORY.md",
    "workspaceContains:.claude/hooks/**",
    "workspaceContains:.claude/commands/**",
    "workspaceContains:.claude/instructions.md",
    "workspaceContains:.claude/memory/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "skillgate.simulateInvocation",
        "title": "SkillGate: Simulate Invocation"
      },
      {
        "command": "skillgate.openOnboarding",
        "title": "SkillGate: Open Setup Panel"
      },
      {
        "command": "skillgate.preflight.retry",
        "title": "SkillGate: Retry Setup Checks"
      },
      {
        "command": "skillgate.generatePrChecklist",
        "title": "SkillGate: Generate PR Checklist"
      },
      {
        "command": "skillgate.scanWorkspace",
        "title": "SkillGate: Scan Workspace"
      },
      {
        "command": "skillgate.submitScanReport",
        "title": "SkillGate: Submit Scan Report"
      },
      {
        "command": "skillgate.initPolicyFile",
        "title": "SkillGate: Initialize Policy File"
      },
      {
        "command": "skillgate.openApprovalRequest",
        "title": "SkillGate: Open Approval Request"
      },
      {
        "command": "skillgate.signApproval",
        "title": "SkillGate: Sign Approval (Guided)"
      },
      {
        "command": "skillgate.verifyApproval",
        "title": "SkillGate: Verify Approval (Guided)"
      },
      {
        "command": "skillgate.openApprovalCenter",
        "title": "SkillGate: Open Approval Center"
      },
      {
        "command": "skillgate.approveInstructionLine",
        "title": "SkillGate: Approve Instruction Line"
      },
      {
        "command": "skillgate.approveHook",
        "title": "SkillGate: Approve Hook"
      }
    ],
    "configuration": {
      "title": "SkillGate",
      "properties": {
        "skillgate.binaryPath": {
          "type": "string",
          "default": "skillgate",
          "description": "Path to SkillGate CLI binary"
        },
        "skillgate.sidecarUrl": {
          "type": "string",
          "default": "http://127.0.0.1:9911",
          "description": "Expert override: explicit local SkillGate sidecar URL. When set, overrides sidecar mode and port settings."
        },
        "skillgate.sidecarMode": {
          "type": "string",
          "default": "shared",
          "enum": [
            "shared",
            "managed-isolation"
          ],
          "markdownDescription": "Sidecar routing mode. `shared` uses one sidecar endpoint for all projects. `managed-isolation` auto-selects a deterministic per-workspace port."
        },
        "skillgate.sidecarBasePort": {
          "type": "number",
          "default": 9911,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Base port used for shared mode and as the seed for managed-isolation port selection."
        },
        "skillgate.policyDebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "description": "Debounce for policy and lint diagnostics"
        },
        "skillgate.instructionDebounceMs": {
          "type": "number",
          "default": 800,
          "minimum": 200,
          "description": "Debounce for instruction file diagnostics"
        }
      }
    },
    "walkthroughs": [
      {
        "id": "skillgate.getStarted",
        "title": "SkillGate Guided Flow",
        "description": "Enterprise-ready in-editor flow: setup, policy, simulation, checklist, approvals.",
        "steps": [
          {
            "id": "step.setup",
            "title": "Open Setup Panel",
            "description": "Run [SkillGate: Open Setup Panel](command:skillgate.openOnboarding) and get all checks green."
          },
          {
            "id": "step.policy",
            "title": "Initialize Policy",
            "description": "Run [SkillGate: Initialize Policy File](command:skillgate.initPolicyFile) to create baseline policy."
          },
          {
            "id": "step.simulate",
            "title": "Run Simulation",
            "description": "Run [SkillGate: Simulate Invocation](command:skillgate.simulateInvocation) to preview runtime decision impact."
          },
          {
            "id": "step.checklist",
            "title": "Generate PR Checklist",
            "description": "Run [SkillGate: Generate PR Checklist](command:skillgate.generatePrChecklist). It copies checklist and opens markdown preview."
          },
          {
            "id": "step.approvals",
            "title": "Process Approvals",
            "description": "Open [SkillGate: Open Approval Center](command:skillgate.openApprovalCenter), then use guided sign and verify commands."
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "tsc -p .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
